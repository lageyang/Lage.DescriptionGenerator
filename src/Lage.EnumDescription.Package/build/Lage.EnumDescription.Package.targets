<Project>
    <Target Name="_LageEnumDescription_FrameworkCheck" BeforeTargets="BeforeBuild;CoreCompile">
        <PropertyGroup>
            <_Lage_Supported>false</_Lage_Supported>
            <_Lage_Supported Condition="$(TargetFramework.StartsWith('net7')) OR $(TargetFramework.StartsWith('net8')) OR $(TargetFramework.StartsWith('net9'))">true</_Lage_Supported>
        </PropertyGroup>

        <Error
          Condition="'$(_Lage_Supported)' != 'true'"
          Code="LAGE_PKG_001"
          Text="错误：Lage.EnumDescription.Package 不支持当前的目标框架 '$(TargetFramework)'。请将项目升级到 .NET 7.0 或更高版本。" />
    </Target>
</Project>